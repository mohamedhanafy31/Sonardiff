{
  "name": "sonardiff-backend",
  "version": "1.0.0",
  "description": "SonarDiff MVP backend — API server and worker",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.6",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-roll": "^4.0.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "postgres": "^3.4.9",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^6.12.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/diff": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
